<%- include('partials/header', { title }) %>
  <section class="page page--safari about-intro">
    <div class="page__hero-img animate-slide-up">
      <img src="https://images.unsplash.com/photo-1539650116574-75c0c6d73f6e?w=900&q=80" alt="Safari adventure">
    </div>
    <h1>About Jungal Safari</h1>
    <p class="about-tagline"><%= message %></p>
    <p class="about-desc">We offer everything from comfortable standard stays to luxury tented camps and cottages—so whether you want an authentic bush experience or a five-star safari lodge, we have the right stage for you. Flights, transfers, and guided routes are all part of the journey.</p>
  </section>

  <section class="safari-route">
    <h2 class="section-title">Safari Route & Transport</h2>
    <div class="route-map-wrap animate-slide-up">
      <div class="route-map">
        <div class="route-map__plane" title="Fly to safari">✈</div>
        <svg class="route-map__svg" viewBox="0 0 400 120" aria-hidden="true">
          <path class="route-map__path" d="M 20 60 Q 100 20 200 60 T 380 60" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="6 4"/>
          <circle class="route-map__dot" cx="20" cy="60" r="6"/>
          <circle class="route-map__dot" cx="200" cy="60" r="6"/>
          <circle class="route-map__dot" cx="380" cy="60" r="6"/>
        </svg>
        <div class="route-map__labels">
          <span class="route-map__label">Arrival</span>
          <span class="route-map__label">Base Camp</span>
          <span class="route-map__label">Safari</span>
        </div>
      </div>
      <p class="route-note">We arrange flights to camp and 4×4 safari routes so you reach every stage in comfort.</p>
    </div>
  </section>

  <section class="stages">
    <h2 class="section-title">Our Stages — Tents & Cottages</h2>
    <p class="stages-intro">From basic bush camps to luxury lodges. Choose your style.</p>
    <div class="stages-grid">
      <div class="stage-card animate-slide-up">
        <div class="stage-card__img">
          <img src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=500&q=80" alt="Standard tent">
        </div>
        <div class="stage-card__body">
          <h3>Standard</h3>
          <p>Comfortable tents and cottages with essential amenities. Perfect for adventurers who want authenticity without compromise.</p>
        </div>
      </div>
      <div class="stage-card animate-slide-up">
        <div class="stage-card__img">
          <img src="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=500&q=80" alt="Comfort tent">
        </div>
        <div class="stage-card__body">
          <h3>Comfort</h3>
          <p>Spacious tents and cottages with en-suite facilities. A step up for those who want comfort in the wild.</p>
        </div>
      </div>
      <div class="stage-card animate-slide-up">
        <div class="stage-card__img">
          <img src="https://images.unsplash.com/photo-1571896349842-33c89424de2d?w=500&q=80" alt="Luxury lodge">
        </div>
        <div class="stage-card__body">
          <h3>Luxury</h3>
          <p>Premium tented camps and safari cottages with full service, fine dining, and unforgettable views.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-more">
    <h2 class="section-title">What We Provide</h2>
    <ul class="provide-list">
      <li>Normal to luxury accommodation (tents, cottages, lodges)</li>
      <li>Guided safari drives and walking trails</li>
      <li>Flight transfers and 4×4 route coverage</li>
      <li>Meals and bush dinners</li>
      <li>Wildlife experts and safety-first trips</li>
    </ul>
  </section>
<%- include('partials/footer') %>
